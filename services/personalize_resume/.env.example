# Copy to .env and fill in your key.

# Required. Get a free key at https://console.groq.com/keys
GROQ_API_KEY=

# Groq model to use. llama-3.3-70b-versatile is available on Groq's free tier.
# GROQ_MODEL=llama-3.3-70b-versatile

# Name/path of the Tectonic binary, if not on PATH as `tectonic`.
# TECTONIC_BIN=tectonic
