# Copy to .env and adjust as needed. All values are optional.

# Where the Handshake session lives. Defaults to search_listings' own
# .auth/handshake.json, since this service reuses that session rather than
# capturing its own.
# HANDSHAKE_STORAGE_STATE=../search_listings/.auth/handshake.json

# Run the service browser headless.
# HEADLESS=true

# Navigation / selector timeout in milliseconds.
# NAV_TIMEOUT_MS=30000

# Handshake base URL.
# HANDSHAKE_BASE_URL=https://app.joinhandshake.com

# Where your contact info / screening-question answers live.
# PROFILE_PATH=.profile/profile.json
