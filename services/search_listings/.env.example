# Copy to .env and adjust as needed. All values are optional.

# Where the captured Handshake session is stored/read.
# HANDSHAKE_STORAGE_STATE=.auth/handshake.json

# Run the service browser headless (the auth-capture script is always headed).
# HEADLESS=true

# Navigation / selector timeout in milliseconds.
# NAV_TIMEOUT_MS=30000

# Handshake base URL.
# HANDSHAKE_BASE_URL=https://app.joinhandshake.com

# Max listings returned per request.
# MAX_LISTINGS=25
